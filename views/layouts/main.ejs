<!DOCTYPE html>
<html class="light" dir="rtl" lang="ar">
<%- include('../partials/head') %>
<body class="text-on-background bg-[#F8FAFC]">

    <% if (isAuthenticated) { %>
        <%- include('../partials/sidebar') %>
        <%- include('../partials/header') %>
        
        <!-- Main Content Area with RTL offset -->
        <main class="mr-0 lg:mr-[280px] pt-16 min-h-screen p-md lg:p-2xl transition-all duration-300">
            <%- body %>
        </main>
    <% } else { %>
        <!-- Minimal layout for Login/Auth pages -->
        <main class="min-h-screen flex items-center justify-center p-md bg-[#F8FAFC]">
            <%- body %>
        </main>
    <% } %>

    <%- include('../partials/toast') %>
    <%- include('../partials/modal') %>
    <%- include('../partials/skeleton') %>

    <script src="/js/main.js"></script>
</body>
</html>
