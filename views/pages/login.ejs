<!DOCTYPE html>
<html dir="rtl" lang="ar">
<head>
    <meta charset="UTF-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>تسجيل الدخول - نظام إدارة المخزون</title>

    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com"/>
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans+Arabic:wght@400;500;600;700&display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>

    <!-- Tailwind Config (Kinetic Ledger Design System) -->
    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "outline-variant": "#c7c4d8",
                        "on-background": "#1b1b24",
                        "on-surface-variant": "#464555",
                        "surface-container-lowest": "#ffffff",
                        "surface-dim": "#dcd8e5",
                        "primary-container": "#4f46e5",
                        "inverse-on-surface": "#f3effc",
                        "surface-variant": "#e4e1ee",
                        "background": "#fcf8ff",
                        "error-container": "#ffdad6",
                        "primary-fixed-dim": "#c3c0ff",
                        "on-primary-fixed": "#0f0069",
                        "on-primary-container": "#dad7ff",
                        "inverse-surface": "#302f39",
                        "surface-container-low": "#f5f2ff",
                        "surface-container-high": "#eae6f4",
                        "surface": "#fcf8ff",
                        "surface-container-highest": "#e4e1ee",
                        "on-surface": "#1b1b24",
                        "surface-tint": "#4d44e3",
                        "error": "#ba1a1a",
                        "on-secondary": "#ffffff",
                        "on-error-container": "#93000a",
                        "primary-fixed": "#e2dfff",
                        "secondary": "#505f76",
                        "on-primary": "#ffffff",
                        "inverse-primary": "#c3c0ff",
                        "secondary-fixed": "#d3e4fe",
                        "on-error": "#ffffff",
                        "secondary-container": "#d0e1fb",
                        "primary": "#3525cd",
                        "on-secondary-container": "#54647a",
                        "surface-container": "#f0ecf9",
                        "surface-bright": "#fcf8ff",
                        "outline": "#777587"
                    },
                    borderRadius: {
                        "DEFAULT": "0.5rem",
                        "sm": "0.25rem",
                        "md": "0.75rem",
                        "lg": "1rem",
                        "xl": "1.5rem",
                        "full": "9999px"
                    },
                    spacing: {
                        "xs": "4px",
                        "sm": "8px",
                        "base": "8px",
                        "md": "16px",
                        "lg": "24px",
                        "xl": "32px",
                        "2xl": "48px",
                        "gutter": "24px",
                        "margin": "32px"
                    },
                    fontFamily: {
                        "sans": ["IBM Plex Sans Arabic", "sans-serif"],
                        "headline-lg": ["IBM Plex Sans Arabic"],
                        "body-lg": ["IBM Plex Sans Arabic"],
                        "display-xl": ["IBM Plex Sans Arabic"],
                        "body-md": ["IBM Plex Sans Arabic"],
                        "label-sm": ["IBM Plex Sans Arabic"],
                        "title-md": ["IBM Plex Sans Arabic"],
                        "caption-xs": ["IBM Plex Sans Arabic"]
                    },
                    fontSize: {
                        "headline-lg": ["28px", { lineHeight: "36px", letterSpacing: "-0.01em", fontWeight: "600" }],
                        "body-lg": ["18px", { lineHeight: "28px", fontWeight: "400" }],
                        "display-xl": ["36px", { lineHeight: "44px", letterSpacing: "-0.02em", fontWeight: "700" }],
                        "body-md": ["16px", { lineHeight: "24px", fontWeight: "400" }],
                        "label-sm": ["14px", { lineHeight: "20px", fontWeight: "500" }],
                        "title-md": ["20px", { lineHeight: "28px", fontWeight: "600" }],
                        "caption-xs": ["12px", { lineHeight: "16px", fontWeight: "500" }]
                    }
                }
            }
        }
    </script>

    <style>
        body { font-family: 'IBM Plex Sans Arabic', sans-serif; }
        .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
        .input-glow:focus-within {
            box-shadow: 0 0 0 3px rgba(79, 70, 229, 0.2);
            border-color: #4f46e5 !important;
        }
    </style>
</head>

<body class="min-h-screen flex items-center justify-center p-lg md:p-2xl bg-[#fcf8ff]">

    <!-- Login Card -->
    <div class="bg-surface-container-lowest rounded-xl shadow-[0_4px_12px_rgba(0,0,0,0.05),0_1px_2px_rgba(0,0,0,0.05)] border border-outline-variant w-full max-w-[440px] p-xl flex flex-col gap-xl">

        <!-- Header Section -->
        <div class="flex flex-col items-center text-center gap-sm">
            <!-- Brand Icon -->
            <div class="w-16 h-16 bg-primary-container/10 rounded-full flex items-center justify-center mb-sm">
                <span class="material-symbols-outlined text-primary text-3xl" style="font-variation-settings: 'FILL' 1;">warehouse</span>
            </div>
            <span class="font-title-md text-title-md text-on-surface-variant uppercase tracking-wider">مخزن الأحذية</span>
            <h1 class="font-headline-lg text-headline-lg text-on-surface">تسجيل دخول المسؤول</h1>
            <p class="font-body-md text-body-md text-on-surface-variant">الرجاء إدخال بيانات الاعتماد الخاصة بك للوصول إلى لوحة التحكم.</p>
        </div>

        <!-- Form -->
        <form id="loginForm" action="/login" class="flex flex-col gap-lg" method="POST">

            <!-- Error Message -->
            <div id="errorMessage" class="hidden bg-red-50 text-red-700 p-3 rounded-lg text-sm border border-red-200 flex items-center gap-2">
                <span class="material-symbols-outlined text-[18px]">error</span>
                <span id="errorText"></span>
            </div>

            <!-- Username -->
            <div class="flex flex-col gap-xs">
                <label class="font-label-sm text-label-sm text-on-surface-variant" for="username">اسم المستخدم</label>
                <div class="relative flex items-center border border-outline-variant rounded-lg bg-surface-container-lowest input-glow transition-all duration-200">
                    <div class="absolute right-0 pr-sm flex items-center pointer-events-none">
                        <span class="material-symbols-outlined text-outline">person</span>
                    </div>
                    <input class="w-full bg-transparent border-none focus:ring-0 py-sm pr-[40px] pl-md font-body-md text-body-md text-on-surface rounded-lg"
                           id="username" name="username" placeholder="أدخل اسم المستخدم" type="text" required/>
                </div>
            </div>

            <!-- Password -->
            <div class="flex flex-col gap-xs">
                <label class="font-label-sm text-label-sm text-on-surface-variant" for="password">كلمة المرور</label>
                <div class="relative flex items-center border border-outline-variant rounded-lg bg-surface-container-lowest input-glow transition-all duration-200">
                    <div class="absolute right-0 pr-sm flex items-center pointer-events-none">
                        <span class="material-symbols-outlined text-outline">lock</span>
                    </div>
                    <input class="w-full bg-transparent border-none focus:ring-0 py-sm pr-[40px] pl-[40px] font-body-md text-body-md text-on-surface rounded-lg"
                           id="password" name="password" placeholder="أدخل كلمة المرور" type="password" required/>
                    <button id="togglePassword" class="absolute left-0 pl-sm flex items-center text-outline hover:text-primary transition-colors cursor-pointer" type="button">
                        <span class="material-symbols-outlined">visibility_off</span>
                    </button>
                </div>
            </div>

            <!-- Remember Me & Forgot Password -->
            <div class="flex items-center justify-between">
                <div class="flex items-center gap-xs">
                    <input class="w-4 h-4 text-primary border-outline-variant rounded focus:ring-primary-container" id="remember" name="remember" type="checkbox"/>
                    <label class="font-label-sm text-label-sm text-on-surface-variant cursor-pointer" for="remember">تذكرني</label>
                </div>
                <a class="font-label-sm text-label-sm text-primary hover:opacity-80 transition-colors" href="#">نسيت كلمة المرور؟</a>
            </div>

            <!-- Submit Button -->
            <button id="loginBtn"
                    class="w-full bg-primary text-on-primary font-title-md text-title-md py-md rounded-lg shadow-sm hover:bg-primary-container transition-all duration-200 active:scale-95 border-t border-white/20"
                    type="submit">
                تسجيل الدخول
            </button>

        </form>
    </div>

    <script src="/js/login.js"></script>
</body>
</html>
