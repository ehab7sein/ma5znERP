<div class="flex flex-col sm:flex-row justify-between sm:items-end mb-lg gap-4">
    <div class="flex items-center">
        <a href="/products" class="text-on-surface-variant hover:text-primary transition-colors ml-md bg-white border border-outline-variant rounded-lg p-2 shadow-soft hover:shadow-hover">
            <span class="material-symbols-outlined">arrow_forward</span>
        </a>
        <div>
            <h2 class="font-display-xl text-display-xl text-on-background mb-xs">مقاسات الموديل: <%= product.model_name %></h2>
            <p class="font-body-md text-body-md text-on-surface-variant"><%= product.category %> | <%= product.color %> | <%= product.brand || 'بدون علامة' %></p>
        </div>
    </div>
    <button id="addBtn" class="bg-primary text-on-primary font-label-sm text-label-sm py-2 px-6 rounded-lg shadow-soft hover:shadow-hover transition-all-200 scale-98 active:scale-95 flex items-center gap-sm">
        <span class="material-symbols-outlined text-[18px]">add</span>
        إضافة مقاس جديد
    </button>
</div>

<div class="bg-white rounded-xl border border-outline-variant shadow-soft overflow-hidden flex flex-col">
    <div class="overflow-x-auto min-h-[300px]">
        <table class="w-full text-right">
            <thead class="bg-slate-50 border-b border-outline-variant">
                <tr>
                    <th class="py-3 px-lg font-label-sm text-label-sm text-secondary uppercase">المقاس</th>
                    <th class="py-3 px-lg font-label-sm text-label-sm text-secondary uppercase">الكمية الحالية</th>
                    <th class="py-3 px-lg font-label-sm text-label-sm text-secondary uppercase">الحد الأدنى</th>
                    <th class="py-3 px-lg font-label-sm text-label-sm text-secondary uppercase">الحالة</th>
                    <th class="py-3 px-lg font-label-sm text-label-sm text-secondary uppercase text-left w-[150px]">إجراءات</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-outline-variant" id="sizesTableBody">
                <!-- Data rendered via JS -->
            </tbody>
        </table>
    </div>
</div>

<!-- Modal Form -->
<div id="sizeModal" class="fixed inset-0 z-[60] hidden overflow-y-auto" aria-labelledby="modal-title" role="dialog" aria-modal="true">
    <div class="flex items-center justify-center min-h-screen pt-4 px-4 pb-20 text-center sm:p-0">
        <div class="fixed inset-0 bg-on-background/50 backdrop-blur-sm transition-opacity" aria-hidden="true" onclick="document.getElementById('cancelBtn').click()"></div>
        <span class="hidden sm:inline-block sm:align-middle sm:h-screen" aria-hidden="true">&#8203;</span>
        
        <div class="inline-block align-bottom bg-white rounded-xl text-right overflow-hidden shadow-hover transform transition-all sm:my-8 sm:align-middle sm:max-w-md sm:w-full border border-outline-variant relative">
            <div class="absolute right-0 top-0 bottom-0 w-1 bg-primary"></div>
            
            <form id="sizeForm">
                <div class="bg-white px-lg pt-lg pb-md">
                    <h3 class="font-title-md text-title-md text-on-background mb-lg flex items-center gap-sm" id="modalTitle">
                        <span class="material-symbols-outlined text-primary">format_size</span>
                        إضافة مقاس جديد
                    </h3>
                    <input type="hidden" id="sizeId" name="id">
                    
                    <div class="space-y-md">
                        <div>
                            <label class="block font-label-sm text-label-sm text-on-surface-variant mb-1">المقاس <span class="text-error">*</span></label>
                            <input type="text" name="size" required class="w-full bg-white border border-outline-variant rounded-lg py-2 px-3 focus:outline-none focus:ring-2 focus:ring-primary-container focus:border-primary text-body-md transition-all">
                        </div>
                        
                        <div id="quantityGroup">
                            <label class="block font-label-sm text-label-sm text-on-surface-variant mb-1">الكمية الافتتاحية <span class="text-error">*</span></label>
                            <input type="number" name="quantity" min="0" value="0" required class="w-full bg-white border border-outline-variant rounded-lg py-2 px-3 focus:outline-none focus:ring-2 focus:ring-primary-container focus:border-primary text-body-md transition-all">
                            <p class="font-caption-xs text-caption-xs text-secondary mt-1">تستخدم فقط لإدخال الرصيد الافتتاحي.</p>
                        </div>

                        <div>
                            <label class="block font-label-sm text-label-sm text-on-surface-variant mb-1">الحد الأدنى للتنبيه <span class="text-error">*</span></label>
                            <input type="number" name="minimum_quantity" min="0" value="5" required class="w-full bg-white border border-outline-variant rounded-lg py-2 px-3 focus:outline-none focus:ring-2 focus:ring-primary-container focus:border-primary text-body-md transition-all">
                        </div>
                    </div>
                </div>
                <div class="bg-surface-container-lowest px-lg py-md border-t border-outline-variant flex flex-row-reverse gap-sm">
                    <button type="submit" id="saveBtn" class="bg-primary text-on-primary font-label-sm text-label-sm py-2 px-6 rounded-lg shadow-soft hover:shadow-hover transition-all-200">
                        حفظ
                    </button>
                    <button type="button" id="cancelBtn" class="bg-white border border-outline-variant text-primary font-label-sm text-label-sm py-2 px-6 rounded-lg shadow-soft hover:bg-surface-container-low transition-all-200">
                        إلغاء
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    const currentProductId = '<%= product.id %>';
    
    // Theme config for the JS rendering
    window.themeClasses = {
        tableRow: 'hover:bg-slate-50 transition-colors',
        tdText: 'py-3 px-lg text-body-md text-on-background font-bold',
        tdMuted: 'py-3 px-lg text-body-md text-on-surface-variant',
        chipSuccess: 'bg-emerald-50 text-emerald-700 px-2 py-0.5 rounded-full text-caption-xs font-bold inline-block',
        chipWarning: 'bg-amber-50 text-amber-700 px-2 py-0.5 rounded-full text-caption-xs font-bold inline-block',
        chipError: 'bg-rose-50 text-rose-700 px-2 py-0.5 rounded-full text-caption-xs font-bold inline-block',
        btnEdit: 'text-primary hover:bg-primary-container/10 p-1.5 rounded-md transition-colors material-symbols-outlined text-[20px] ml-1',
        btnDelete: 'text-error hover:bg-error-container/20 p-1.5 rounded-md transition-colors material-symbols-outlined text-[20px]'
    };
</script>
<script src="/js/product-sizes.js"></script>
