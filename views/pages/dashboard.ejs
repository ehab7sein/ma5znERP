        lowStockShoesCount: { color: 'text-amber-600 bg-amber-50', border: 'bg-amber-500', icon: 'warning', subtitle: 'تنبيه مخزون' },
        lowStockPackagingCount: { color: 'text-rose-600 bg-rose-50', border: 'bg-rose-500', icon: 'inventory', subtitle: 'عاجل' },
        totalShoesQuantity: { wide: true, border: 'bg-primary', icon: 'layers' },
        totalPackagingQuantity: { wide: true, border: 'bg-secondary', icon: 'box' }
    };
</script>
