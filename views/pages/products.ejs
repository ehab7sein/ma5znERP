<div class="flex flex-col sm:flex-row justify-between sm:items-end mb-lg gap-4">
    <div>
        <h2 class="font-display-xl text-display-xl text-on-background mb-xs">موديلات الأحذية</h2>
        <p class="font-body-md text-body-md text-on-surface-variant">إدارة موديلات الأحذية والمقاسات التابعة لها.</p>
    </div>
    <div class="flex gap-sm">
        <button id="addBtn" class="bg-primary text-on-primary font-label-sm text-label-sm py-2 px-6 rounded-lg shadow-soft hover:shadow-hover transition-all-200 scale-98 active:scale-95 flex items-center gap-sm">
            <span class="material-symbols-outlined text-[18px]">add</span>
            إضافة موديل جديد
        </button>
        <button onclick="window.showPrintDialog({type:'stock'})" class="bg-white border border-outline-variant text-secondary font-label-sm text-label-sm py-2 px-4 rounded-lg shadow-soft hover:shadow-hover transition-all-200 flex items-center gap-xs">
            <span class="material-symbols-outlined text-[18px]">print</span>
        </button>
    </div>
</div>

<div class="bg-white rounded-xl border border-outline-variant shadow-soft overflow-hidden flex flex-col">
    <!-- Search Bar -->
    <div class="p-4 border-b border-outline-variant bg-surface-container-lowest flex items-center">
        <div class="relative w-full max-w-md">
            <span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 text-on-surface-variant">search</span>
            <input type="text" id="searchInput" placeholder="ابحث باسم الموديل، الفئة، أو اللون... (Ctrl+K)" class="w-full pl-4 pr-10 py-2 bg-surface-container-low border border-outline-variant rounded-lg text-label-sm focus:ring-2 focus:ring-primary-container focus:border-primary transition-all-200">
        </div>
    </div>
    
    <div class="overflow-x-auto min-h-[300px]">
        <table class="w-full text-right">
            <thead class="bg-slate-50 border-b border-outline-variant">
                <tr>
                    <th class="py-3 px-lg font-label-sm text-label-sm text-secondary uppercase">اسم الموديل</th>
                    <th class="py-3 px-lg font-label-sm text-label-sm text-secondary uppercase">الفئة</th>
                    <th class="py-3 px-lg font-label-sm text-label-sm text-secondary uppercase">اللون</th>
                    <th class="py-3 px-lg font-label-sm text-label-sm text-secondary uppercase">المقاسات</th>
                    <th class="py-3 px-lg font-label-sm text-label-sm text-secondary uppercase">إجمالي الكمية</th>
                    <th class="py-3 px-lg font-label-sm text-label-sm text-secondary uppercase text-left w-[150px]">إجراءات</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-outline-variant" id="productsTableBody">
                <!-- Data rendered via JS -->
            </tbody>
        </table>
    </div>
</div>

<!-- Modal Form -->
<div id="productModal" class="fixed inset-0 z-[60] hidden overflow-y-auto" aria-labelledby="modal-title" role="dialog" aria-modal="true">
    <div class="flex items-center justify-center min-h-screen pt-4 px-4 pb-20 text-center sm:p-0">
        <div class="fixed inset-0 bg-on-background/50 backdrop-blur-sm transition-opacity" aria-hidden="true" onclick="document.getElementById('cancelBtn').click()"></div>
        <span class="hidden sm:inline-block sm:align-middle sm:h-screen" aria-hidden="true">&#8203;</span>
        
        <div class="inline-block align-bottom bg-white rounded-xl text-right overflow-hidden shadow-hover transform transition-all sm:my-8 sm:align-middle sm:max-w-lg sm:w-full border border-outline-variant relative">
            <div class="absolute right-0 top-0 bottom-0 w-1 bg-primary"></div>
            
            <form id="productForm">
                <div class="bg-white px-lg pt-lg pb-md">
                    <h3 class="font-title-md text-title-md text-on-background mb-lg flex items-center gap-sm" id="modalTitle">
                        <span class="material-symbols-outlined text-primary">edit_square</span>
                        إضافة موديل جديد
                    </h3>
                    <input type="hidden" id="productId" name="id">
                    
                    <div class="space-y-md">
                        <div>
                            <label class="block font-label-sm text-label-sm text-on-surface-variant mb-1">اسم الموديل <span class="text-error">*</span></label>
                            <input type="text" name="model_name" required class="w-full bg-white border border-outline-variant rounded-lg py-2 px-3 focus:outline-none focus:ring-2 focus:ring-primary-container focus:border-primary text-body-md transition-all">
                        </div>
                        <div>
                            <label class="block font-label-sm text-label-sm text-on-surface-variant mb-1">الفئة <span class="text-error">*</span></label>
                            <select name="category" required class="w-full bg-white border border-outline-variant rounded-lg py-2 px-3 focus:outline-none focus:ring-2 focus:ring-primary-container focus:border-primary text-body-md transition-all">
                                <option value="">اختر الفئة...</option>
                                <option value="رجالي">رجالي</option>
                                <option value="حريمي">حريمي</option>
                                <option value="أطفالي">أطفالي</option>
                                <option value="رياضي">رياضي</option>
                            </select>
                        </div>
                        <div>
                            <label class="block font-label-sm text-label-sm text-on-surface-variant mb-1">اللون <span class="text-error">*</span></label>
                            <input type="text" name="color" required class="w-full bg-white border border-outline-variant rounded-lg py-2 px-3 focus:outline-none focus:ring-2 focus:ring-primary-container focus:border-primary text-body-md transition-all">
                        </div>
                        <div class="grid grid-cols-2 gap-md">
                            <div>
                                <label class="block font-label-sm text-label-sm text-on-surface-variant mb-1">الخامة</label>
                                <input type="text" name="material" class="w-full bg-white border border-outline-variant rounded-lg py-2 px-3 focus:outline-none focus:ring-2 focus:ring-primary-container focus:border-primary text-body-md transition-all">
                            </div>
                            <div>
                                <label class="block font-label-sm text-label-sm text-on-surface-variant mb-1">العلامة التجارية</label>
                                <input type="text" name="brand" class="w-full bg-white border border-outline-variant rounded-lg py-2 px-3 focus:outline-none focus:ring-2 focus:ring-primary-container focus:border-primary text-body-md transition-all">
                            </div>
                        </div>
                        <div>
                            <label class="block font-label-sm text-label-sm text-on-surface-variant mb-1">ملاحظات</label>
                            <textarea name="notes" rows="2" class="w-full bg-white border border-outline-variant rounded-lg py-2 px-3 focus:outline-none focus:ring-2 focus:ring-primary-container focus:border-primary text-body-md transition-all"></textarea>
                        </div>
                    </div>
                </div>
                <div class="bg-surface-container-lowest px-lg py-md border-t border-outline-variant flex flex-row-reverse gap-sm">
                    <button type="submit" id="saveBtn" class="bg-primary text-on-primary font-label-sm text-label-sm py-2 px-6 rounded-lg shadow-soft hover:shadow-hover transition-all-200">
                        حفظ
                    </button>
                    <button type="button" id="cancelBtn" class="bg-white border border-outline-variant text-primary font-label-sm text-label-sm py-2 px-6 rounded-lg shadow-soft hover:bg-surface-container-low transition-all-200">
                        إلغاء
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    // Overriding table styles in products.js via CSS classes config
    window.themeClasses = {
        tableRow: 'hover:bg-slate-50 transition-colors cursor-pointer group',
        tdText: 'py-3 px-lg text-body-md text-on-background group-hover:text-primary transition-colors',
        tdMuted: 'py-3 px-lg text-body-md text-on-surface-variant',
        chip: 'bg-surface-container-high text-on-surface-variant px-2 py-0.5 rounded-full text-caption-xs font-bold inline-block',
        btnEdit: 'text-primary hover:bg-primary-container/10 p-1.5 rounded-md transition-colors material-symbols-outlined text-[20px] ml-1',
        btnDelete: 'text-error hover:bg-error-container/20 p-1.5 rounded-md transition-colors material-symbols-outlined text-[20px]'
    };
</script>
<script src="/js/products.js"></script>
