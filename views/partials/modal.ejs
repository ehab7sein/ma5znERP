<div id="globalModal" class="fixed inset-0 z-[100] hidden overflow-y-auto" aria-labelledby="modal-title" role="dialog" aria-modal="true">
    <div class="flex items-center justify-center min-h-screen pt-4 px-4 pb-20 text-center sm:p-0">
        <div class="fixed inset-0 bg-on-background/50 backdrop-blur-sm transition-opacity" aria-hidden="true" id="globalModalBackdrop"></div>
        <span class="hidden sm:inline-block sm:align-middle sm:h-screen" aria-hidden="true">&#8203;</span>
        
        <div class="inline-block align-bottom bg-white rounded-xl text-right overflow-hidden shadow-hover transform transition-all sm:my-8 sm:align-middle sm:max-w-md sm:w-full border border-outline-variant relative">
            <div class="absolute right-0 top-0 bottom-0 w-1 bg-primary" id="globalModalAccent"></div>
            
            <div class="bg-white px-lg pt-lg pb-md">
                <h3 class="font-title-md text-title-md text-on-background mb-sm flex items-center gap-sm" id="globalModalTitle">
                    <span class="material-symbols-outlined text-primary" id="globalModalIcon">info</span>
                    <span id="globalModalTitleText">عنوان النافذة</span>
                </h3>
                <div class="mt-2">
                    <p class="font-body-md text-body-md text-on-surface-variant" id="globalModalMessage">
                        رسالة تأكيد أو تنبيه.
                    </p>
                </div>
            </div>
            
            <div class="bg-surface-container-lowest px-lg py-md border-t border-outline-variant flex flex-row-reverse gap-sm">
                <button type="button" id="globalModalConfirmBtn" class="bg-primary text-on-primary font-label-sm text-label-sm py-2 px-6 rounded-lg shadow-soft hover:shadow-hover transition-all-200">
                    تأكيد
                </button>
                <button type="button" id="globalModalCancelBtn" class="bg-white border border-outline-variant text-primary font-label-sm text-label-sm py-2 px-6 rounded-lg shadow-soft hover:bg-surface-container-low transition-all-200">
                    إلغاء
                </button>
            </div>
        </div>
    </div>
</div>
