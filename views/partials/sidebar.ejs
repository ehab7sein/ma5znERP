<!-- SideNavBar -->
<aside class="fixed right-0 top-0 h-full w-[280px] border-l border-outline-variant bg-white dark:bg-surface-container-low shadow-sm flex flex-col h-full overflow-y-auto rtl z-50 transition-transform duration-300 transform translate-x-full lg:translate-x-0" id="mainSidebar">
    
    <div class="p-lg flex items-center gap-md border-b border-outline-variant">
        <div class="w-10 h-10 rounded-lg bg-primary-container flex items-center justify-center text-on-primary-container">
            <span class="material-symbols-outlined fill">inventory_2</span>
        </div>
        <div>
            <h1 class="font-headline-lg text-headline-lg font-bold text-primary dark:text-inverse-primary text-xl">مخزن الأحذية</h1>
            <p class="font-caption-xs text-caption-xs text-on-surface-variant">نظام إدارة الموارد</p>
        </div>
    </div>
    
    <div class="p-md">
        <a href="/transactions/in" class="w-full bg-primary text-on-primary font-label-sm text-label-sm py-2 rounded-lg shadow-soft hover:shadow-hover transition-all-200 scale-98 active:scale-95 transition-transform flex items-center justify-center gap-sm cursor-pointer">
            <span class="material-symbols-outlined">add</span>
            إضافة شحنة جديدة
        </a>
    </div>
    
    <nav class="flex-1 py-sm flex flex-col gap-xs">
        <a href="/dashboard" class="flex items-center gap-md px-lg py-md <%= typeof activePage !== 'undefined' && activePage === 'dashboard' ? 'text-primary bg-primary-container/10 border-r-4 border-primary font-bold' : 'text-on-surface-variant hover:bg-surface-container-highest border-r-4 border-transparent' %> transition-all duration-200 font-body-md text-body-md">
            <span class="material-symbols-outlined <%= typeof activePage !== 'undefined' && activePage === 'dashboard' ? 'fill' : '' %>">dashboard</span>
            لوحة التحكم
        </a>
        <a href="/products" class="flex items-center gap-md px-lg py-md <%= typeof activePage !== 'undefined' && activePage === 'products' ? 'text-primary bg-primary-container/10 border-r-4 border-primary font-bold' : 'text-on-surface-variant hover:bg-surface-container-highest border-r-4 border-transparent' %> transition-all duration-200 font-body-md text-body-md">
            <span class="material-symbols-outlined <%= typeof activePage !== 'undefined' && activePage === 'products' ? 'fill' : '' %>">ice_skating</span>
            موديلات الأحذية
        </a>
        <a href="/transactions/in" class="flex items-center gap-md px-lg py-md <%= typeof activePage !== 'undefined' && activePage === 'stock_in' ? 'text-primary bg-primary-container/10 border-r-4 border-primary font-bold' : 'text-on-surface-variant hover:bg-surface-container-highest border-r-4 border-transparent' %> transition-all duration-200 font-body-md text-body-md">
            <span class="material-symbols-outlined <%= typeof activePage !== 'undefined' && activePage === 'stock_in' ? 'fill' : '' %>">add_box</span>
            إضافة مخزون
        </a>
        <a href="/transactions/out" class="flex items-center gap-md px-lg py-md <%= typeof activePage !== 'undefined' && activePage === 'stock_out' ? 'text-primary bg-primary-container/10 border-r-4 border-primary font-bold' : 'text-on-surface-variant hover:bg-surface-container-highest border-r-4 border-transparent' %> transition-all duration-200 font-body-md text-body-md">
            <span class="material-symbols-outlined <%= typeof activePage !== 'undefined' && activePage === 'stock_out' ? 'fill' : '' %>">outbound</span>
            صرف مخزون
        </a>
        <a href="/transactions" class="flex items-center gap-md px-lg py-md <%= typeof activePage !== 'undefined' && activePage === 'transactions' ? 'text-primary bg-primary-container/10 border-r-4 border-primary font-bold' : 'text-on-surface-variant hover:bg-surface-container-highest border-r-4 border-transparent' %> transition-all duration-200 font-body-md text-body-md">
            <span class="material-symbols-outlined <%= typeof activePage !== 'undefined' && activePage === 'transactions' ? 'fill' : '' %>">history_toggle_off</span>
            سجل الحركة
        </a>
        <a href="/packaging" class="flex items-center gap-md px-lg py-md <%= typeof activePage !== 'undefined' && activePage === 'packaging' ? 'text-primary bg-primary-container/10 border-r-4 border-primary font-bold' : 'text-on-surface-variant hover:bg-surface-container-highest border-r-4 border-transparent' %> transition-all duration-200 font-body-md text-body-md">
            <span class="material-symbols-outlined <%= typeof activePage !== 'undefined' && activePage === 'packaging' ? 'fill' : '' %>">package_2</span>
            مواد التغليف
        </a>
        <a href="/reports" class="flex items-center gap-md px-lg py-md <%= typeof activePage !== 'undefined' && activePage === 'reports' ? 'text-primary bg-primary-container/10 border-r-4 border-primary font-bold' : 'text-on-surface-variant hover:bg-surface-container-highest border-r-4 border-transparent' %> transition-all duration-200 font-body-md text-body-md">
            <span class="material-symbols-outlined <%= typeof activePage !== 'undefined' && activePage === 'reports' ? 'fill' : '' %>">assessment</span>
            التقارير
        </a>
        <a href="/print/stock" target="_blank" class="flex items-center gap-md px-lg py-md text-on-surface-variant hover:bg-surface-container-highest border-r-4 border-transparent transition-all duration-200 font-body-md text-body-md">
            <span class="material-symbols-outlined">print</span>
            طباعة تقرير المخزون
        </a>
    </nav>
    
    <div class="mt-auto border-t border-outline-variant py-sm">
        <a href="#" class="flex items-center gap-md px-lg py-md text-on-surface-variant hover:bg-surface-container-highest transition-all duration-200 font-body-md text-body-md">
            <span class="material-symbols-outlined">account_circle</span>
            الملف الشخصي (<%= user ? user.username : '' %>)
        </a>
        <form action="/api/auth/logout" method="POST" class="m-0" id="sidebarLogoutForm">
            <button type="submit" class="w-full flex items-center gap-md px-lg py-md text-error hover:bg-error-container/20 transition-all duration-200 font-body-md text-body-md">
                <span class="material-symbols-outlined">logout</span>
                تسجيل الخروج
            </button>
        </form>
    </div>
</aside>

<!-- Mobile Overlay -->
<div id="mobileOverlay" class="fixed inset-0 bg-on-background/50 z-40 hidden lg:hidden"></div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const sidebar = document.getElementById('mainSidebar');
        const overlay = document.getElementById('mobileOverlay');
        const toggleBtn = document.getElementById('sidebarToggleBtn');

        if(toggleBtn && sidebar && overlay) {
            toggleBtn.addEventListener('click', () => {
                sidebar.classList.toggle('translate-x-full');
                overlay.classList.toggle('hidden');
            });

            overlay.addEventListener('click', () => {
                sidebar.classList.add('translate-x-full');
                overlay.classList.add('hidden');
            });
        }
        
        // Use Fetch for logout to utilize Toast
        const logoutForm = document.getElementById('sidebarLogoutForm');
        if (logoutForm) {
            logoutForm.addEventListener('submit', async (e) => {
                e.preventDefault();
                try {
                    const res = await fetch('/api/auth/logout', { method: 'POST' });
                    const result = await res.json();
                    if(result.success) {
                        window.location.href = result.redirectUrl || '/login';
                    }
                } catch(err) {
                    console.error('Logout error');
                }
            });
        }
    });
</script>
