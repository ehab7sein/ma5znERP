<div id="toastContainer" class="fixed top-4 left-1/2 -translate-x-1/2 sm:left-auto sm:right-4 sm:translate-x-0 z-[100] flex flex-col gap-3 rtl text-right pointer-events-none"></div>

<script>
    window.showToast = function(message, type = 'success') {
        const container = document.getElementById('toastContainer');
        if (!container) return;

        const toast = document.createElement('div');
        
        let colorClass = '';
        let icon = '';
        let borderClass = '';
        
        if (type === 'success') {
            colorClass = 'bg-emerald-50 text-emerald-800';
            borderClass = 'border-emerald-200';
            icon = '<span class="material-symbols-outlined text-emerald-600">check_circle</span>';
        } else if (type === 'error') {
            colorClass = 'bg-error-container/20 text-error';
            borderClass = 'border-error/20';
            icon = '<span class="material-symbols-outlined text-error">error</span>';
        } else if (type === 'warning') {
            colorClass = 'bg-amber-50 text-amber-800';
            borderClass = 'border-amber-200';
            icon = '<span class="material-symbols-outlined text-amber-600">warning</span>';
        }

        toast.className = `flex items-center gap-3 px-4 py-3 rounded-xl shadow-hover border ${colorClass} ${borderClass} translate-x-full opacity-0 transition-all duration-300 pointer-events-auto min-w-[280px] max-w-[400px]`;
        
        toast.innerHTML = `
            ${icon}
            <span class="font-body-md text-body-md flex-1">${message}</span>
            <button class="text-current opacity-70 hover:opacity-100 transition-opacity" onclick="this.parentElement.remove()">
                <span class="material-symbols-outlined text-[18px]">close</span>
            </button>
        `;

        container.appendChild(toast);

        requestAnimationFrame(() => {
            toast.classList.remove('translate-x-full', 'opacity-0');
        });

        setTimeout(() => {
            toast.classList.add('opacity-0', 'translate-x-4');
            setTimeout(() => toast.remove(), 300);
        }, 3500);
    };
</script>
