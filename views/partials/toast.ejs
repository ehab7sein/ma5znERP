<div id="toastContainer" class="fixed bottom-5 left-5 z-[100] flex flex-col gap-3 rtl text-right pointer-events-none"></div>

<script>
    window.showToast = function(message, type = 'success') {
        const container = document.getElementById('toastContainer');
        if (!container) return;

        const toast = document.createElement('div');
        
        let colorClass = '';
        let icon = '';
        let borderClass = '';
        
        if (type === 'success') {
            colorClass = 'bg-emerald-50 text-emerald-800';
            borderClass = 'border-emerald-200';
            icon = '<span class="material-symbols-outlined text-emerald-600">check_circle</span>';
        } else if (type === 'error') {
            colorClass = 'bg-error-container/20 text-error';
            borderClass = 'border-error/20';
            icon = '<span class="material-symbols-outlined text-error">error</span>';
        } else if (type === 'warning') {
            colorClass = 'bg-amber-50 text-amber-800';
            borderClass = 'border-amber-200';
            icon = '<span class="material-symbols-outlined text-amber-600">warning</span>';
        }

        toast.className = `flex items-center gap-3 px-4 py-3 rounded-lg shadow-hover border ${colorClass} ${borderClass} transform translate-y-full opacity-0 transition-all duration-300 pointer-events-auto`;
        
        toast.innerHTML = `
            ${icon}
            <span class="font-body-md text-body-md">${message}</span>
            <button class="ml-2 text-current opacity-70 hover:opacity-100" onclick="this.parentElement.remove()">
                <span class="material-symbols-outlined text-[18px]">close</span>
            </button>
        `;

        container.appendChild(toast);

        // Animate in
        requestAnimationFrame(() => {
            toast.classList.remove('translate-y-full', 'opacity-0');
        });

        // Auto remove
        setTimeout(() => {
            toast.classList.add('opacity-0', 'scale-95');
            setTimeout(() => toast.remove(), 300);
        }, 4000);
    };
</script>
