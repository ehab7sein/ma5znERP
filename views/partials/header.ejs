<header class="bg-white shadow-sm h-16 flex items-center justify-between px-6 z-10 flex-shrink-0">
    <div class="flex items-center">
        <!-- Mobile menu button -->
        <button id="mobileMenuBtn" class="md:hidden text-gray-500 hover:text-indigo-600 focus:outline-none ml-4">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
            </svg>
        </button>
        
        <!-- Breadcrumbs -->
        <div class="hidden sm:flex text-sm text-gray-500 font-medium" id="breadcrumbs">
            <!-- Dynamically populated -->
        </div>
    </div>
    
    <div class="flex items-center space-x-4 space-x-reverse">
        <div class="flex items-center">
            <span class="text-sm font-medium text-gray-700 ml-2"><%= (typeof user !== 'undefined' && user.username) ? user.username : 'مدير النظام' %></span>
            <div class="w-8 h-8 rounded-full bg-indigo-100 flex items-center justify-center text-indigo-600 font-bold">
                <%= (typeof user !== 'undefined' && user.username) ? user.username.charAt(0).toUpperCase() : 'U' %>
            </div>
        </div>
    </div>
</header>
